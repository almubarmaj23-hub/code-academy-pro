    "description": "",
    "html": "<html><head><meta name=\"color-scheme\" content=\"light dark\"></head><body><pre style=\"word-wrap: break-word; white-space: pre-wrap;\"><!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n  <meta charset=\"UTF-8\"/>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n\n  <!-- ═══ Primary SEO ═══ -->\n  <title>Code Academy Pro | تعلم البرمجة بالعربي من الصفر</title>\n  <meta name=\"description\" content=\"منصة Code Academy Pro لتعلم البرمجة بالعربي — دورات في HTML, CSS, JavaScript, Python, React, AI ومحرر كود تفاعلي مجاني.\"/>\n  <meta name=\"keywords\" content=\"تعلم البرمجة, برمجة بالعربي, HTML, CSS, JavaScript, Python, React, دورات برمجة, كود أكاديمي\"/>\n  <meta name=\"author\" content=\"Code Academy Pro\"/>\n  <meta name=\"robots\" content=\"index, follow\"/>\n  <link rel=\"canonical\" href=\"https://almubarmaj23-hub.github.io/code-academy-pro/\"/>\n\n  <!-- ═══ Open Graph (Facebook / WhatsApp / LinkedIn) ═══ -->\n  <meta property=\"og:type\"        content=\"website\"/>\n  <meta property=\"og:url\"         content=\"https://almubarmaj23-hub.github.io/code-academy-pro/\"/>\n  <meta property=\"og:title\"       content=\"Code Academy Pro | تعلم البرمجة بالعربي\"/>\n  <meta property=\"og:description\" content=\"تعلم البرمجة من الصفر بمحتوى عربي متميز — دورات تفاعلية ومحرر كود مباشر واختبارات ذكية.\"/>\n  <meta property=\"og:image\"       content=\"https://almubarmaj23-hub.github.io/code-academy-pro/og-image.png\"/>\n  <meta property=\"og:locale\"      content=\"ar_AR\"/>\n  <meta property=\"og:site_name\"   content=\"Code Academy Pro\"/>\n\n  <!-- ═══ Twitter Card ═══ -->\n  <meta name=\"twitter:card\"        content=\"summary_large_image\"/>\n  <meta name=\"twitter:title\"       content=\"Code Academy Pro | تعلم البرمجة بالعربي\"/>\n  <meta name=\"twitter:description\" content=\"منصة عربية مجانية لتعلم البرمجة — HTML, CSS, JS, Python, AI\"/>\n  <meta name=\"twitter:image\"       content=\"https://almubarmaj23-hub.github.io/code-academy-pro/og-image.png\"/>\n\n  <!-- ═══ Favicon ═══ -->\n  <link rel=\"icon\" type=\"image/svg+xml\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%236c63ff'/><text y='.9em' font-size='65' x='12'>💻</text></svg>\"/>\n  <link rel=\"apple-touch-icon\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%236c63ff'/><text y='.9em' font-size='65' x='12'>💻</text></svg>\"/>\n\n  <!-- ═══ Structured Data (JSON-LD) ═══ -->\n  <script type=\"application/ld+json\">\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"EducationalOrganization\",\n    \"name\": \"Code Academy Pro\",\n    \"description\": \"منصة عربية لتعلم البرمجة من الصفر حتى الاحتراف\",\n    \"url\": \"https://almubarmaj23-hub.github.io/code-academy-pro/\",\n    \"inLanguage\": \"ar\",\n    \"offers\": {\n      \"@type\": \"Offer\",\n      \"price\": \"0\",\n      \"priceCurrency\": \"USD\",\n      \"availability\": \"https://schema.org/InStock\"\n    }\n  }\n  </script>\n\n  <!-- ═══ Stylesheets ═══ -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/>\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin/>\n  <link rel=\"stylesheet\" href=\"style.css\"/>\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\"\n        integrity=\"sha512-Avb2QiuDEEvB4bZJYdft2mNjVShBftLdPG8FJ0V7irTLQ8Uo0qcPxh4Plh7eqjn8smb2EjL/7M6y1zeJ0OmA==\"\n        crossorigin=\"anonymous\" referrerpolicy=\"no-referrer\"/>\n  <link href=\"https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&family=Fira+Code:wght@400;500&display=swap\"\n        rel=\"stylesheet\"/>\n</head>\n<body data-theme=\"dark\">\n\n<a href=\"#main-content\" class=\"skip-link\">تخطى إلى المحتوى الرئيسي</a>\n\n\n<div id=\"preloader\">\n  <div class=\"loader-inner\">\n    <div class=\"code-text\">&lt;CodeAcademy/&gt;</div>\n    <div class=\"loader-bar\"><div class=\"loader-fill\"></div></div>\n  </div>\n</div>\n\n<div id=\"particles-bg\"></div>\n\n<nav id=\"navbar\">\n  <div class=\"nav-container\">\n    <a href=\"#home\" class=\"nav-logo\" aria-label=\"Code Academy Pro - الصفحة الرئيسية\">\n      <span class=\"logo-icon\"><i class=\"fas fa-code\" aria-hidden=\"true\"></i></span>\n      <span class=\"logo-text\">Code<span class=\"accent\">Academy</span></span>\n    </a>\n    <ul class=\"nav-links\" role=\"list\" id=\"navLinks\">\n      <li><a href=\"#home\" class=\"nav-link active\" aria-current=\"page\">الرئيسية</a></li>\n      <li><a href=\"#courses\" class=\"nav-link\">الدورات</a></li>\n      <li><a href=\"#roadmap\" class=\"nav-link\">خارطة الطريق</a></li>\n      <li><a href=\"#articles\" class=\"nav-link\">المقالات</a></li>\n      <li><a href=\"#editor\" class=\"nav-link\">المحرر</a></li>\n      <li><a href=\"#quiz\" class=\"nav-link\">الاختبارات</a></li>\n    </ul>\n    <div class=\"nav-actions\">\n      <button class=\"btn-theme\" id=\"themeToggle\" aria-label=\"تبديل الوضع المظلم والفاتح\" aria-pressed=\"false\"><i class=\"fas fa-moon\" aria-hidden=\"true\"></i></button>\n      <button class=\"btn-primary\" onclick=\"scrollToSection('courses')\">ابدأ التعلم <i class=\"fas fa-arrow-left\" aria-hidden=\"true\"></i></button>\n      <button class=\"hamburger\" id=\"hamburger\" aria-label=\"فتح قائمة التنقل\" aria-expanded=\"false\" aria-controls=\"navLinks\"><i class=\"fas fa-bars\" aria-hidden=\"true\"></i></button>\n    </div>\n  </div>\n</nav>\n\n<main id=\"main-content\">\n\n<!-- Hero -->\n<section id=\"home\" class=\"hero\" aria-label=\"قسم الترحيب\">\n  <div class=\"hero-content\">\n    <div class=\"hero-badge\"><i class=\"fas fa-star\" aria-hidden=\"true\"></i> منصة التعلم الأولى عربياً</div>\n    <h1 class=\"hero-title\">تعلّم <span class=\"gradient-text\">البرمجة</span><br/>وابنِ مستقبلك الرقمي</h1>\n    <p class=\"hero-subtitle\">من الصفر إلى الاحتراف — 8 دورات شاملة، محرر كود تفاعلي، اختبارات ذكية، ومقالات احترافية بالعربية</p>\n    <div class=\"hero-btns\">\n      <button class=\"btn-hero-primary\" onclick=\"scrollToSection('courses')\"><i class=\"fas fa-rocket\" aria-hidden=\"true\"></i> ابدأ مجاناً</button>\n      <button class=\"btn-hero-secondary\" onclick=\"scrollToSection('editor')\"><i class=\"fas fa-play\" aria-hidden=\"true\"></i> جرب المحرر</button>\n    </div>\n    <div class=\"hero-stats\">\n      <div class=\"hero-stat\"><span class=\"stat-num\" data-target=\"27400\">0</span><span class=\"stat-plus\">+</span><span class=\"stat-label\">طالب</span></div>\n      <div class=\"hero-stat\"><span class=\"stat-num\" data-target=\"8\">0</span><span class=\"stat-plus\"></span><span class=\"stat-label\">دورات</span></div>\n      <div class=\"hero-stat\"><span class=\"stat-num\" data-target=\"97\">0</span><span class=\"stat-plus\">%</span><span class=\"stat-label\">رضا المتعلمين</span></div>\n    </div>\n  </div>\n  <div class=\"hero-visual\">\n    <div class=\"code-window\">\n      <div class=\"window-bar\">\n        <span class=\"dot red\"></span><span class=\"dot yellow\"></span><span class=\"dot green\"></span>\n        <span class=\"window-title\">main.py</span>\n      </div>\n      <div class=\"code-content\" id=\"typingCode\"></div>\n    </div>\n    <div class=\"floating-badge badge-1\"><i class=\"fab fa-python\" aria-hidden=\"true\"></i> Python</div>\n    <div class=\"floating-badge badge-2\"><i class=\"fab fa-js\" aria-hidden=\"true\"></i> JavaScript</div>\n    <div class=\"floating-badge badge-3\"><i class=\"fab fa-react\" aria-hidden=\"true\"></i> React</div>\n    <div class=\"floating-badge badge-4\"><i class=\"fas fa-brain\" aria-hidden=\"true\"></i> AI / ML</div>\n  </div>\n</section>\n\n<!-- Features -->\n<section class=\"features-section\" id=\"features\" aria-label=\"مميزات المنصة\">\n  <div class=\"container\">\n    <div class=\"features-grid\">\n      <div class=\"feature-card\"><div class=\"feature-icon\"><i class=\"fas fa-laptop-code\" aria-hidden=\"true\"></i></div><h3>تعلم تفاعلي</h3><p>كود مباشر في المتصفح بدون إعداد بيئة</p></div>\n      <div class=\"feature-card\"><div class=\"feature-icon\"><i class=\"fas fa-project-diagram\" aria-hidden=\"true\"></i></div><h3>مشاريع حقيقية</h3><p>طبّق ما تعلمته في مشاريع تضاف لـ Portfolio</p></div>\n      <div class=\"feature-card\"><div class=\"feature-icon\"><i class=\"fas fa-certificate\" aria-hidden=\"true\"></i></div><h3>شهادات معتمدة</h3><p>احصل على شهادة إتمام لكل دورة تُكملها</p></div>\n      <div class=\"feature-card\"><div class=\"feature-icon\"><i class=\"fas fa-users\" aria-hidden=\"true\"></i></div><h3>مجتمع داعم</h3><p>مجتمع نشط من المتعلمين والمدرسين</p></div>\n    </div>\n  </div>\n</section>\n\n<!-- Courses -->\n<section id=\"courses\" class=\"courses-section\" aria-label=\"الدورات التعليمية\">\n  <div class=\"container\">\n    <div class=\"section-header\">\n      <span class=\"section-tag\">📚 مكتبة الدورات</span>\n      <h2>اختر مسارك التعليمي</h2>\n      <p>8 دورات شاملة مصممة بعناية من خبراء الصناعة</p>\n    </div>\n    <div class=\"courses-filter\">\n      <button class=\"filter-btn active\" data-filter=\"all\" role=\"tab\" aria-pressed=\"true\" aria-label=\"عرض جميع الدورات\">الكل</button>\n      <button class=\"filter-btn\" data-filter=\"web\" role=\"tab\" aria-pressed=\"false\" aria-label=\"فلترة دورات تطوير الويب\">تطوير الويب</button>\n      <button class=\"filter-btn\" data-filter=\"mobile\" role=\"tab\" aria-pressed=\"false\" aria-label=\"فلترة دورات الموبايل\">الموبايل</button>\n      <button class=\"filter-btn\" data-filter=\"ai\" role=\"tab\" aria-pressed=\"false\" aria-label=\"فلترة دورات الذكاء الاصطناعي\">الذكاء الاصطناعي</button>\n      <button class=\"filter-btn\" data-filter=\"backend\" role=\"tab\" aria-pressed=\"false\" aria-label=\"فلترة دورات الباك إند\">الباك إند</button>\n    </div>\n    <div class=\"courses-grid\" id=\"coursesGrid\"></div>\n  </div>\n</section>\n\n<!-- Roadmap -->\n<section id=\"roadmap\" class=\"roadmap-section\" aria-label=\"خارطة طريق البرمجة\">\n  <div class=\"container\">\n    <div class=\"section-header\">\n      <span class=\"section-tag\">🗺️ خارطة الطريق</span>\n      <h2>مسار المطور الشامل</h2>\n      <p>اتبع هذا المسار لتصبح مطور ويب محترف في أقل من سنة</p>\n    </div>\n    <div class=\"roadmap-container\">\n      <div class=\"roadmap-step\"><div class=\"step-icon\"><i class=\"fab fa-html5\" aria-hidden=\"true\"></i></div><div class=\"step-content\"><span class=\"step-num\">المرحلة 1</span><h3>أساسيات الويب</h3><p>HTML5 • CSS3 • JavaScript ES6+</p><div class=\"step-duration\">⏱ 4-6 أسابيع</div></div></div>\n      <div class=\"roadmap-step\"><div class=\"step-icon\"><i class=\"fab fa-git-alt\" aria-hidden=\"true\"></i></div><div class=\"step-content\"><span class=\"step-num\">المرحلة 2</span><h3>Git وأدوات التطوير</h3><p>Git • GitHub • Terminal • VS Code</p><div class=\"step-duration\">⏱ 1-2 أسابيع</div></div></div>\n      <div class=\"roadmap-step\"><div class=\"step-icon\"><i class=\"fab fa-react\" aria-hidden=\"true\"></i></div><div class=\"step-content\"><span class=\"step-num\">المرحلة 3</span><h3>الفريم ووركس الأمامية</h3><p>React.js • Tailwind CSS • TypeScript</p><div class=\"step-duration\">⏱ 6-8 أسابيع</div></div></div>\n      <div class=\"roadmap-step\"><div class=\"step-icon\"><i class=\"fab fa-node-js\" aria-hidden=\"true\"></i></div><div class=\"step-content\"><span class=\"step-num\">المرحلة 4</span><h3>الباك إند والقواعد</h3><p>Node.js • Express • MongoDB • PostgreSQL</p><div class=\"step-duration\">⏱ 6-8 أسابيع</div></div></div>\n      <div class=\"roadmap-step\"><div class=\"step-icon\"><i class=\"fas fa-cloud\" aria-hidden=\"true\"></i></div><div class=\"step-content\"><span class=\"step-num\">المرحلة 5</span><h3>النشر والـ DevOps</h3><p>Docker • AWS/GCP • CI/CD • Nginx</p><div class=\"step-duration\">⏱ 3-4 أسابيع</div></div></div>\n    </div>\n  </div>\n</section>\n\n\n\n<!-- Articles -->\n<section id=\"articles\" class=\"articles-section\" aria-label=\"الدروس المجانية\">\n  <div class=\"container\">\n    <div class=\"section-header\">\n      <span class=\"section-tag\">📝 المدونة التقنية</span>\n      <h2>مقالات واختصارات مفيدة</h2>\n      <p>محتوى تقني منتقى يساعدك في رحلتك البرمجية</p>\n    </div>\n    <div class=\"articles-grid\" id=\"articlesGrid\"></div>\n  </div>\n</section>\n\n<!-- Editor -->\n<section id=\"editor\" class=\"editor-section\" aria-label=\"المحرر التفاعلي\">\n  <div class=\"container\">\n    <div class=\"section-header\">\n      <span class=\"section-tag\">💻 المحرر التفاعلي</span>\n      <h2>اكتب الكود وشاهد النتيجة فوراً</h2>\n      <p>جرّب البرمجة مباشرة في المتصفح — HTML، CSS، JavaScript</p>\n    </div>\n    <div class=\"editor-wrapper\">\n      <div class=\"editor-sidebar\">\n        <div class=\"lang-btn active\" data-lang=\"html\" onclick=\"setLang('html')\"><i class=\"fab fa-html5\" aria-hidden=\"true\"></i> HTML</div>\n        <div class=\"lang-btn\" data-lang=\"css\" onclick=\"setLang('css')\"><i class=\"fab fa-css3-alt\" aria-hidden=\"true\"></i> CSS</div>\n        <div class=\"lang-btn\" data-lang=\"js\" onclick=\"setLang('js')\"><i class=\"fab fa-js\" aria-hidden=\"true\"></i> JS</div>\n        <div class=\"lang-btn\" data-lang=\"python\" onclick=\"setLang('python')\"><i class=\"fab fa-python\" aria-hidden=\"true\"></i> Python</div>\n      </div>\n      <div class=\"editor-main\">\n        <div class=\"editor-header\">\n          <span class=\"editor-filename\" id=\"editorFilename\">index.html</span>\n          <div class=\"editor-actions\">\n            <button onclick=\"safeRunCode()\" class=\"btn-run\" aria-label=\"تشغيل الكود\"><i class=\"fas fa-play\" aria-hidden=\"true\"></i> تشغيل</button>\n            <button onclick=\"resetCode()\" class=\"btn-reset\" aria-label=\"إعادة تعيين الكود\"><i class=\"fas fa-undo\" aria-hidden=\"true\"></i> إعادة</button>\n            <button onclick=\"copyCode()\" class=\"btn-copy\" aria-label=\"نسخ الكود\"><i class=\"fas fa-copy\" aria-hidden=\"true\"></i> نسخ</button>\n          </div>\n        </div>\n        <textarea id=\"codeEditor\" role=\"textbox\" aria-label=\"محرر الكود البرمجي\" aria-multiline=\"true\" spellcheck=\"false\" spellcheck=\"false\" autocomplete=\"off\"></textarea>\n      </div>\n      <div class=\"editor-output\">\n        <div class=\"output-header\"><i class=\"fas fa-eye\" aria-hidden=\"true\"></i> معاينة النتيجة</div>\n        <iframe id=\"outputFrame\" sandbox=\"allow-scripts\"></iframe>\n        <div id=\"consoleOutput\" role=\"status\" aria-live=\"polite\" aria-label=\"مخرجات تشغيل الكود\" class=\"console-output\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Quiz -->\n<section id=\"quiz\" class=\"quiz-section\" aria-label=\"اختبار المعرفة\">\n  <div class=\"container\">\n    <div class=\"section-header\">\n      <span class=\"section-tag\">🧩 اختبر نفسك</span>\n      <h2>بنك أسئلة شامل</h2>\n      <p>30 سؤالاً في HTML وCSS وJavaScript وPython وReact وGit وأكثر</p>\n    </div>\n    <div class=\"quiz-wrapper\">\n      <div class=\"quiz-category-bar\" id=\"quizCategoryBar\"></div>\n      <div class=\"quiz-box\" id=\"quizBox\">\n        <div class=\"quiz-progress\">\n          <div class=\"quiz-progress-bar\"><div class=\"quiz-fill\" id=\"quizFill\"></div></div>\n          <span id=\"quizCounter\">السؤال 1 من 10</span>\n        </div>\n        <div class=\"quiz-cat-label\" id=\"quizCatLabel\"></div>\n        <div class=\"quiz-question\" id=\"quizQuestion\"></div>\n        <div class=\"quiz-options\" id=\"quizOptions\"></div>\n        <div class=\"quiz-result\" id=\"quizResult\" role=\"status\" aria-live=\"assertive\" style=\"display:none\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- Testimonials -->\n<section id=\"testimonials\" class=\"testimonials-section\" aria-label=\"آراء الطلاب\">\n  <div class=\"container\">\n    <div class=\"section-header\">\n      <span class=\"section-tag\">⭐ آراء المتعلمين</span>\n      <h2>ماذا يقول طلابنا؟</h2>\n      <p>آلاف الطلاب غيّروا مساراتهم المهنية معنا</p>\n    </div>\n    <div class=\"testimonials-slider\" id=\"testimonialsGrid\"></div>\n  </div>\n</section>\n\n<!-- Stats -->\n<section id=\"stats\" class=\"stats-section\" aria-label=\"إحصائيات المنصة\">\n  <div class=\"container\">\n    <div class=\"stats-grid\">\n      <div class=\"stat-card\"><div class=\"stat-icon\"><i class=\"fas fa-users\" aria-hidden=\"true\"></i></div><div class=\"stat-value\"><span class=\"count\" data-target=\"27400\">0</span>+</div><div class=\"stat-label\">طالب مسجّل</div></div>\n      <div class=\"stat-card\"><div class=\"stat-icon\"><i class=\"fas fa-book-open\" aria-hidden=\"true\"></i></div><div class=\"stat-value\"><span class=\"count\" data-target=\"8\">0</span></div><div class=\"stat-label\">دورات متاحة</div></div>\n      <div class=\"stat-card\"><div class=\"stat-icon\"><i class=\"fas fa-video\" aria-hidden=\"true\"></i></div><div class=\"stat-value\"><span class=\"count\" data-target=\"419\">0</span>+</div><div class=\"stat-label\">درس في المناهج</div></div>\n      <div class=\"stat-card\"><div class=\"stat-icon\"><i class=\"fas fa-trophy\" aria-hidden=\"true\"></i></div><div class=\"stat-value\"><span class=\"count\" data-target=\"3200\">0</span>+</div><div class=\"stat-label\">شهادة صدرت</div></div>\n    </div>\n  </div>\n</section>\n\n<!-- Footer -->\n</main>\n\n</main><!-- /#main-content -->\n\n<footer class=\"footer\">\n  <div class=\"container\">\n    <div class=\"footer-grid\">\n      <div class=\"footer-brand\">\n        <div class=\"nav-logo\" style=\"margin-bottom:1rem\"><span class=\"logo-icon\"><i class=\"fas fa-code\" aria-hidden=\"true\"></i></span><span class=\"logo-text\">Code<span class=\"accent\">Academy</span></span></div>\n        <p>منصتك الأولى لتعلم البرمجة باللغة العربية</p>\n        <div class=\"social-links\">\n          <a href=\"#\"><i class=\